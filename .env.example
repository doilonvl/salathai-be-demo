PORT=5000
NODE_ENV=development
API_BASE=/api/v1

# MongoDB
URI_MONGODB=mongodb+srv://user:pass@cluster.mongodb.net/salathai?retryWrites=true&w=majority

# CORS
CORS_ORIGINS=http://localhost:3000

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES=15m
REFRESH_EXPIRES=7d

# Cookie
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_ADDR=noreply@example.com

# Sentry (optional)
# SENTRY_DSN=
