# Server
PORT=5000
NODE_ENV=development
API_BASE=/api/v1

# MongoDB
URI_MONGODB=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# CORS (comma-separated origins, leave empty to allow all)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# JWT
JWT_ACCESS_SECRET=your-long-random-access-secret-here
JWT_REFRESH_SECRET=your-long-random-refresh-secret-here
JWT_EXPIRES=15m
REFRESH_EXPIRES=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_ROOT_FOLDER=your-folder-name
# CLOUDINARY_UPLOAD_PRESET=

# SMTP (Mailjet example)
SMTP_HOST=in-v3.mailjet.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_mailjet_api_key
SMTP_PASS=your_mailjet_secret_key

# Mail settings
MAIL_FROM_NAME=Your Restaurant Name
MAIL_FROM_ADDR=noreply@yourdomain.com
MAIL_TO_ADDR=contact@yourdomain.com
ENFORCE_MAIL_DELIVERY=false

# Sentry (optional, leave empty to disable)
SENTRY_DSN=
